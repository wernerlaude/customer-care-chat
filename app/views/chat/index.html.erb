<div class="chat-container" data-controller="chat">
  <!-- Header -->
  <div class="chat-header">
    <button class="back-button">‹</button>
    <div class="agent-info">
      <div class="agent-avatar">🤖</div>
      <div class="agent-details">
        <h3>Customer Care Agent</h3>
        <p>Unterstützt durch KI</p>
      </div>
    </div>
  </div>

  <!-- Messages -->
  <div class="chat-messages" data-chat-target="messages">
    <% @messages.each do |message| %>
      <div class="message <%= message.from_visitor? ? 'user' : 'agent' %>">
        <div class="message-avatar">
          <%= message.from_visitor? ? '👤' : '🤖' %>
        </div>
        <div>
          <div class="message-content">
            <%= simple_format(message.content) %>
          </div>
          <div class="message-time">
            <%= message.created_at.strftime("%H:%M") %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Quick Actions -->
  <div class="quick-actions">
    <button class="quick-reply"
            data-reply="Ist Ihre Frage damit beantwortet?"
            data-action="click->chat#quickReply">
      Ist Ihre Frage damit beantwortet?
    </button>
    <div class="feedback-buttons">
      <button class="feedback-btn"
              data-feedback="like"
              data-action="click->chat#giveFeedback"
              title="Hilfreich">👍</button>
      <button class="feedback-btn"
              data-feedback="dislike"
              data-action="click->chat#giveFeedback"
              title="Nicht hilfreich">👎</button>
    </div>
  </div>

  <!-- Input Form -->
  <div class="chat-input">
    <%= form_with url: send_message_path, local: true, data: { chat_target: "form" } do |form| %>
      <div class="input-container">
        <%= text_field_tag :content, '',
                           placeholder: "Nachricht schreiben",
                           class: "message-input",
                           data: { chat_target: "input" },
                           autocomplete: "off",
                           required: true %>
        <div class="input-actions">
          <button type="button" class="attachment-btn">📎</button>
          <%= submit_tag "➤", class: "send-btn" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
